{
  "schema": "vmos-experiment-report",
  "schema_version": 1,
  "name": "e0_evidence_harness",
  "checkpoint": "E3-experiment-report-json-schema",
  "commands": [
    {
      "command": "scripts/replay-golden-traces.sh",
      "purpose": "prove golden evidence is machine-checkable"
    },
    {
      "command": "python scripts/validate-runtime-evidence.py --reports-only",
      "purpose": "prove report evidence is machine-checkable"
    }
  ],
  "events": [
    {
      "kind": "EvidenceGateStarted",
      "source": "phase0-smoke"
    },
    {
      "kind": "GoldenTraceReplayValidated",
      "source": "scripts/replay-golden-traces.sh"
    },
    {
      "kind": "RuntimeEvidenceValidated",
      "source": "scripts/validate-runtime-evidence.py"
    }
  ],
  "final_views": {
    "osctl": {
      "schema": "osctl-experiment-report-view-v1",
      "read_only": true
    }
  },
  "metrics": {
    "evidence_classes": 5,
    "feature_implementation_started": 0
  },
  "validation": {
    "contract_ok": true,
    "golden_replay_ok": true,
    "required_reports_present": true
  }
}
