{
  "schema": "vmos-benchmark-report",
  "schema_version": 1,
  "name": "b23_disk_recovery_host_validation",
  "checkpoint": "B23-disk-recovery-benchmark",
  "environment": {
    "mode": "host-validation-semantic-harness",
    "hardware_dependency": "none",
    "measurement_source": "recorded BlockRecoveryBenchmark semantic object",
    "no_goal": "not a calibrated virtio-blk or disk scheduler recovery time"
  },
  "metrics": {
    "benchmark_count": {
      "value": 1,
      "unit": "samples"
    },
    "recovery_nanos": {
      "value": 70000,
      "unit": "semantic-ns"
    },
    "budget_nanos": {
      "value": 150000,
      "unit": "semantic-ns"
    },
    "cancelled_block_waits": {
      "value": 1,
      "unit": "waits"
    },
    "cancelled_wait_tokens": {
      "value": 1,
      "unit": "wait-tokens"
    },
    "released_dma_buffers": {
      "value": 1,
      "unit": "dma-buffers"
    },
    "revoked_device_capabilities": {
      "value": 1,
      "unit": "capabilities"
    },
    "cleanup_effects": {
      "value": 4,
      "unit": "semantic-effects"
    },
    "within_budget": {
      "value": 1,
      "unit": "boolean"
    }
  },
  "validation": {
    "ok": true,
    "notes": [
      "B23 records deterministic host-validation disk recovery evidence in the semantic graph.",
      "Real calibrated disk recovery remains adapter/backend benchmark work after the semantic contract is closed."
