    "budget_nanos": {
      "value": 200000,
      "unit": "semantic-ns"
    },
    "cancelled_socket_waits": {
      "value": 1,
      "unit": "waits"
    },
    "revoked_packet_capabilities": {
      "value": 1,
      "unit": "capabilities"
    },
    "cleanup_effects": {
      "value": 2,
      "unit": "semantic-effects"
    },
    "within_budget": {
      "value": 1,
      "unit": "boolean"
    }
  },
  "validation": {
    "ok": true,
    "notes": [
      "N20 records deterministic host-validation network recovery evidence in the semantic graph.",
      "Real calibrated network recovery remains adapter/backend benchmark work after the semantic contract is closed."
