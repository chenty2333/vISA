{
  "schema": "vmos-fault-injection-scenario",
  "schema_version": 1,
  "name": "i11_io_fault_injection_cleanup",
  "checkpoint": "I11-io-fault-injection",
  "trigger": {
    "kind": "DeviceFault",
    "target": "irq-line-object:9931@1",
    "driver_store": "store:2@2",
    "device": "device-object:9701@1",
    "driver_binding": "driver-store-binding:9961@1",
    "runtime_side_effect": "semantic-cleanup-only"
  },
  "expected_events": [
    {
      "kind": "IoCleanupStarted",
      "cleanup": "io-cleanup:9967@1"
    },
    {
      "kind": "IoCleanupCompleted",
      "cleanup": "io-cleanup:9967@1",
      "cancelled_io_waits": 1,
      "revoked_device_capabilities": 4,
      "released_dma_buffers": 1,
      "released_mmio_regions": 1,
      "released_irq_lines": 1
    },
    {
      "kind": "IoFaultInjected",
      "fault": "io-fault-injection:9968@1",
      "cleanup": "io-cleanup:9967@1"
    }
  ],
  "expected_cleanup": {
    "required": true,
    "cleanup": "io-cleanup:9967@1",
    "reason": "device-fault",
    "cancelled_io_waits": 1,
    "revoked_device_capabilities": 4,
    "released_dma_buffers": 1,
    "released_mmio_regions": 1,
    "released_irq_lines": 1
  },
  "validation": {
    "ok": true,
    "negative_test_contract": "Stale IRQ-line generation and post-cleanup binding reuse must reject before mutation."
  }
}
