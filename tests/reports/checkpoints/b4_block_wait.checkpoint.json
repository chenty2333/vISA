  "phase": "Phase 5 Block / Disk Full Vertical",
  "status": "pass",
  "scope": [
    "Add BlockWait as a stable semantic object owned by semantic_core",
    "Bridge BlockWait to the existing WaitRecord / WaitToken model with exact-generation BlockRequestObject blockers",
    "Resolve BlockWait only through an exact successful BlockCompletionObject",
    "Cancel BlockWait with an explicit WaitCancelReason and propagate cancellation to the underlying WaitToken",
    "Expose block wait roots/counts through semantic package, osctl ViewV1, graph historical edges, replay roots, and roots JSON",
    "Reject stale request generations, duplicate pending waits, and mismatched completions before mutation"
  ],
  "no_goals": [
    "real block IO",
    "real virtio-blk backend",
    "request queue scheduling",
    "DMA-backed block buffer",
    "filesystem adapters",
    "target-side cwasm execution"
  ],
