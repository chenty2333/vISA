        "name": "m7_disk_recovery_time_host_validation",
        "checkpoint": "M7-disk-recovery-time",
        "contract_ok": true,
        "golden_replay_ok": true
      },
      "contract-validation": {
        "ok": true,
        "violation_count": 0
      }
    },
    "invariants": [
      "M7 experiment evidence is backed by first-class BlockRecoveryBenchmark ObjectRef",
      "M7 reuses B23 semantic command, event, ViewV1, and invariant rather than treating backend logs as truth",
      "cleanup effect counts match completed BlockDriverCleanup evidence",
      "stale cleanup generation and recovery budget overrun are osctl-visible negative evidence",
      "BlockRecoveryBenchmark is historical evidence only and creates no live ownership edge"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
