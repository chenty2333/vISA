  "stimulus": {
    "preconditions": [
      "B23 recorded block-recovery-benchmark:20135@1 as semantic disk recovery timing evidence",
      "benchmark references exact cleanup, IO cleanup, backend, block device, driver store, device, and driver binding generations",
      "osctl block-recovery-benchmark list --json exposes stable ViewV1 output"
