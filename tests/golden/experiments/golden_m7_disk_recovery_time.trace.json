        "io_cleanup": "io-cleanup:20108@1",
        "driver_store": "store:7@3",
        "backend": "virtio-blk-backend-object:20034@1",
        "recovery_nanos": 70000,
        "budget_nanos": 150000,
        "expected": "applied"
      },
      {
        "command": "record-block-recovery-benchmark",
        "cleanup": "block-driver-cleanup:20107@2",
        "expected": "rejected",
        "violation": "block recovery benchmark cleanup generation is missing or incomplete"
      },
      {
        "command": "record-block-recovery-benchmark",
        "recovery_nanos": 200000,
        "budget_nanos": 150000,
        "expected": "rejected",
        "violation": "block recovery benchmark exceeds recovery budget"
      },
      {
        "command": "osctl experiment report --json tests/reports/experiments/m7_disk_recovery_time.experiment.json",
        "result": "experiment report validates as vmos-experiment-report"
      }
    ]
  },
  "events": [
    {
      "kind": "BlockRecoveryBenchmarkRecorded",
      "benchmark": "block-recovery-benchmark:20135@1",
      "event": 486,
      "recovery_start_event": 452,
      "recovery_complete_event": 458,
      "recovery_nanos": 70000,
      "budget_nanos": 150000
    }
  ],
  "expected": {
    "views": {
      "block-recovery-benchmark": {
        "kind": "block-recovery-benchmark",
        "id": 20135,
        "generation": 1,
        "state": "recorded",
        "cleanup": "block-driver-cleanup:20107@1",
        "io_cleanup": "io-cleanup:20108@1",
        "recovery_nanos": 70000,
        "budget_nanos": 150000,
        "cancelled_block_waits": 1,
        "cancelled_wait_tokens": 1,
        "released_dma_buffers": 1,
        "revoked_device_capabilities": 1,
        "within_budget": true
      },
      "experiment_report": {
