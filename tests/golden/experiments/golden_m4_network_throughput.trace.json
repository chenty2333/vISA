  "checkpoint": "M4-network-throughput",
  "name": "golden_m4_network_throughput",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/semantic-contract-v0.1/02-object-identity-and-refs.md",
    "references/specs/semantic-contract-v0.1/03-contract-graph-edges.md",
    "references/specs/semantic-contract-v0.1/07-osctl-control-plane.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "real virtio datapath",
    "real smoltcp throughput measurement",
    "real DMA/IOMMU/MMIO/IRQ hardware access",
    "calibrated target network performance number",
    "target-side cwasm execution"
  ],
  "stimulus": {
    "preconditions": [
      "N19 recorded network-benchmark:10067@1 as semantic throughput and latency evidence",
      "benchmark references exact generations for adapter, packet device, tx/rx queues, socket, endpoint, owner store, and backpressure",
      "osctl network-benchmark list --json exposes stable ViewV1 output"
    ],
    "commands": [
      {
        "command": "record-network-benchmark",
        "benchmark": "network-benchmark:10067@1",
        "adapter": "network-stack-adapter:10025@1",
        "packet_device": "packet-device:10002@1",
        "owner_store": "store:9@3",
        "sample_packets": 3,
        "sample_bytes": 6000,
        "measured_nanos": 120000,
        "budget_nanos": 250000,
        "expected": "applied"
      },
      {
        "command": "record-network-benchmark",
        "adapter": "network-stack-adapter:10025@2",
        "expected": "rejected",
        "violation": "network benchmark adapter generation is missing or inactive"
      },
      {
        "command": "record-network-benchmark",
        "measured_nanos": 260000,
        "budget_nanos": 250000,
        "expected": "rejected",
        "violation": "network benchmark exceeds latency budget"
      },
      {
        "command": "osctl experiment report --json tests/reports/experiments/m4_network_throughput.experiment.json",
        "result": "experiment report validates as vmos-experiment-report"
      }
    ]
  },
  "events": [
    {
      "kind": "NetworkBenchmarkRecorded",
      "benchmark": "network-benchmark:10067@1",
      "event": 379,
      "sample_packets": 3,
      "sample_bytes": 6000,
      "measured_nanos": 120000,
      "throughput_bytes_per_sec": 50000000
    }
  ],
  "expected": {
    "views": {
      "network-benchmark": {
        "kind": "network-benchmark",
        "id": 10067,
        "generation": 1,
        "state": "recorded",
        "sample_packets": 3,
        "sample_bytes": 6000,
        "measured_nanos": 120000,
        "budget_nanos": 250000,
        "throughput_bytes_per_sec": 50000000,
        "p50_latency_nanos": 18000,
        "p99_latency_nanos": 48000
      },
      "experiment_report": {
        "schema": "vmos-experiment-report",
        "name": "m4_network_throughput_host_validation",
        "checkpoint": "M4-network-throughput",
        "contract_ok": true,
        "golden_replay_ok": true
      },
      "contract-validation": {
        "ok": true,
        "violation_count": 0
      }
    },
    "invariants": [
      "M4 experiment evidence is backed by first-class NetworkBenchmark ObjectRef",
      "M4 reuses N19 semantic command, event, ViewV1, and invariant rather than treating adapter logs as truth",
      "NetworkBenchmark carries exact generation refs for all network objects",
      "packet accounting closes over tx_completed_packets + rx_resolved_packets + dropped_packets",
      "throughput_bytes_per_sec is derived from sample_bytes and measured_nanos",
      "stale adapter generation and latency budget overrun are osctl-visible negative evidence"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "network_runtime_n19_benchmark_records_throughput_latency_evidence",
      "network_runtime_n19_rejects_stale_adapter_and_budget_overrun",
      "network_runtime_n19_invariants_reject_throughput_metric_drift",
      "network_benchmark_view_v1_exposes_throughput_latency_metrics",
      "semantic_roots_reject_network_benchmark_root_mismatch"
    ],
    "experiment_report": "tests/reports/experiments/m4_network_throughput.experiment.json",
    "osctl_json_view": "network-benchmark list --json",
    "network_benchmark": "network-benchmark:10067@1"
  }
}
