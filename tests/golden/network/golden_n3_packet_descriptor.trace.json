      },
      {
        "id": 2,
        "command": "record-packet-queue-object",
        "packet_queue": "packet-queue:10004@1",
        "role": "rx",
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "record-packet-descriptor-object",
        "packet_descriptor": "packet-descriptor:10006@1",
        "packet_queue": "packet-queue:10004@1",
        "packet_buffer": "packet-buffer:10003@1",
        "slot": 0,
        "length": 64,
        "expected": "applied"
      },
      {
        "id": 4,
        "command": "record-packet-descriptor-object",
        "scenario": "stale packet queue generation",
        "expected": "rejected"
      },
      {
        "id": 5,
        "command": "record-packet-descriptor-object",
        "scenario": "queue role does not match buffer direction",
        "expected": "rejected"
      },
      {
        "id": 6,
        "command": "record-packet-descriptor-object",
        "scenario": "duplicate live slot",
        "expected": "rejected"
      },
      {
        "id": 7,
        "command": "record-packet-descriptor-object",
        "scenario": "duplicate live packet buffer",
        "expected": "rejected"
      }
    ]
  },
  "events": [
    {
      "kind": "PacketDescriptorObjectRecorded",
      "packet_descriptor": "packet-descriptor:10006@1",
      "packet_queue": "packet-queue:10004@1",
      "packet_buffer": "packet-buffer:10003@1",
      "slot": 0,
      "length": 64
    }
  ],
  "expected": {
    "views": {
      "packet-descriptor": {
        "count": 1,
        "packet_descriptor": "packet-descriptor:10006@1",
        "packet_queue": "packet-queue:10004@1",
        "packet_buffer": "packet-buffer:10003@1",
        "slot": 0,
        "length": 64
      },
      "contract-validation": {
        "ok": true,
        "violation_count": 0
      }
    },
    "invariants": [
      "PacketDescriptorObject is a semantic object, not backend queue state",
      "PacketDescriptorObject references exact PacketQueueObject generation",
      "PacketDescriptorObject references exact PacketBufferObject generation",
      "PacketDescriptorObject queue and buffer share one PacketDeviceObject generation",
      "PacketDescriptorObject role and buffer direction must match",
      "PacketDescriptorObject slot is unique per packet queue generation",
      "PacketBufferObject can have at most one live PacketDescriptorObject"
