  "validation": {
    "ok": true,
    "required_tests": [
      "network_runtime_n3_packet_descriptors_record_queue_and_buffer_identity",
      "network_runtime_n3_rejects_stale_duplicate_mismatch_and_overlength_descriptor",
      "network_runtime_n3_invariants_reject_packet_descriptor_generation_leaks",
      "packet_descriptor_view_v1_exposes_queue_buffer_and_length",
      "semantic_roots_reject_packet_descriptor_object_root_mismatch"
    ],
    "osctl_json_view": "packet-descriptor list --json"
