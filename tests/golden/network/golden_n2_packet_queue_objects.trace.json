{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "N2-tx-rx-queue-objects",
  "name": "golden_n2_packet_queue_objects",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md",
    "references/specs/semantic-contract-v0.1/02-object-identity-and-refs.md",
    "references/specs/semantic-contract-v0.1/03-contract-graph-edges.md"
  ],
  "no_goals": [
    "packet descriptors",
    "queue enqueue/dequeue datapath",
    "RX/TX completion semantics",
    "fake net backend behavior",
    "virtio-net backend",
    "smoltcp integration"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "record-packet-device-object",
        "packet_device": "packet-device:10002@1",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "record-packet-queue-object",
        "packet_queue": "packet-queue:10004@1",
        "role": "rx",
        "packet_device": "packet-device:10002@1",
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "record-packet-queue-object",
        "packet_queue": "packet-queue:10005@1",
        "role": "tx",
        "packet_device": "packet-device:10002@1",
        "expected": "applied"
      },
      {
        "id": 4,
        "command": "record-packet-queue-object",
        "scenario": "duplicate rx queue index",
        "expected": "rejected"
      },
      {
        "id": 5,
        "command": "record-packet-queue-object",
        "scenario": "stale packet device generation",
        "expected": "rejected"
      },
      {
        "id": 6,
        "command": "record-packet-queue-object",
        "scenario": "depth exceeds packet device contract",
        "expected": "rejected"
      }
    ]
  },
  "events": [
    {
      "kind": "PacketQueueObjectRecorded",
      "packet_queue": "packet-queue:10004@1",
      "packet_device": "packet-device:10002@1",
      "role": "rx",
      "queue_index": 0,
      "depth": 4
    },
    {
      "kind": "PacketQueueObjectRecorded",
      "packet_queue": "packet-queue:10005@1",
      "packet_device": "packet-device:10002@1",
      "role": "tx",
      "queue_index": 0,
      "depth": 4
    }
  ],
  "expected": {
    "views": {
      "packet-queue": {
        "count": 2,
        "rx": "packet-queue:10004@1",
        "tx": "packet-queue:10005@1",
        "packet_device": "packet-device:10002@1",
        "depth": 4
      },
      "contract-validation": {
        "ok": true,
        "violation_count": 0
      }
    },
    "invariants": [
      "PacketQueueObject is a semantic object, not service queue internals",
      "PacketQueueObject references exact PacketDeviceObject generation",
      "PacketQueueObject role is rx or tx",
      "PacketQueueObject depth cannot exceed the packet device queue contract",
      "PacketQueueObject role+index is unique per packet device generation"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "network_runtime_n2_packet_queues_record_rx_and_tx_contract_identity",
      "network_runtime_n2_rejects_stale_duplicate_and_overdepth_queue",
      "network_runtime_n2_invariants_reject_packet_queue_generation_leak",
      "packet_queue_view_v1_exposes_role_depth_and_packet_device_generation",
      "semantic_roots_reject_packet_queue_object_root_mismatch"
    ],
    "osctl_json_view": "packet-queue list --json"
  }
}
