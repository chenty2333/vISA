{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "I4-mmio-region-object",
  "name": "golden_i4_mmio_region_object",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md",
    "references/specs/semantic-contract-v0.1/02-object-identity-and-refs.md",
    "references/specs/semantic-contract-v0.1/03-contract-graph-edges.md",
    "references/specs/semantic-contract-v0.1/04-capability-authority.md"
  ],
  "no_goals": [
    "real MMIO read/write",
    "real MMIO mapping",
    "raw host pointer or physical mapping truth",
    "real DMA/MMIO/IRQ access",
    "network or block vertical implementation"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "record-device-object",
        "device": "device:9701@1",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "record-mmio-region-object",
        "mmio_region": "mmio-region:9921@1",
        "device": "device:9701@1",
        "resource": "resource:4@1",
        "region_index": 0,
        "offset": 4096,
        "length": 256,
        "access": "read-write",
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "record-mmio-region-object",
        "device": "device:9701@2",
        "expected": "rejected",
        "violation": "mmio region object device generation is missing or inactive"
      },
      {
        "id": 4,
        "command": "record-mmio-region-object",
        "resource_kind": "device",
        "expected": "rejected",
        "violation": "mmio region object resource kind is not mmio-region"
      },
      {
        "id": 5,
        "command": "record-mmio-region-object",
        "resource": "resource:4@2",
        "expected": "rejected",
        "violation": "mmio region object resource generation mismatch"
      },
      {
        "id": 6,
        "command": "record-mmio-region-object",
        "offset": 18446744073709551615,
        "length": 1,
        "expected": "rejected",
        "violation": "mmio region object range overflows"
      },
      {
        "id": 7,
        "command": "record-mmio-region-object",
        "device": "device:9701@1",
        "region_index": 0,
        "expected": "rejected",
        "violation": "mmio region object index already exists for device generation"
      }
    ]
  },
  "events": [
    {
      "kind": "MmioRegionObjectRecorded",
      "mmio_region": "mmio-region:9921@1",
      "device": "device:9701@1",
      "resource": "resource:4@1",
      "region_index": 0,
      "offset": 4096,
      "length": 256,
      "access": "read-write"
    }
  ],
  "expected": {
    "views": {
      "mmio-region": {
        "id": 9921,
        "generation": 1,
        "state": "registered",
        "device": "device:9701@1",
        "resource": "resource:4@1",
        "region_index": 0,
        "offset": 4096,
        "length": 256,
        "access": "read-write"
      },
      "graph-live": {
        "edges": [
          "mmio-region:9921@1 --mmio-region-device--> device:9701@1",
          "mmio-region:9921@1 --mmio-region-resource--> resource:4@1"
        ]
      }
    },
    "invariants": [
      "MmioRegionObject must reference an exact registered DeviceObject generation",
      "MmioRegionObject must reference an exact live ResourceKind::MmioRegion generation",
      "MmioRegionObject range must be nonzero and non-overflowing",
      "MmioRegionObject region_index is unique within a DeviceObject generation",
      "MmioRegionObject is semantic MMIO region evidence, not substrate mapping truth"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "io_runtime_i4_mmio_region_object_records_device_and_resource_identity",
      "io_runtime_i4_rejects_stale_wrong_resource_or_duplicate_mmio_region",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state",
      "semantic_roots_reject_mmio_region_object_root_mismatch"
    ]
  }
}
