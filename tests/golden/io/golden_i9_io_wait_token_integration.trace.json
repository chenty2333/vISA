      "contract-validation": {
        "ok": true,
        "violation_count": 0
      },
      "graph-history": {
        "edges": [
          "io-wait:9963@1 --io-wait-token--> wait-token:9962@1",
          "io-wait:9963@1 --io-wait-driver-store--> store:2@2",
          "io-wait:9963@1 --io-wait-device--> device-object:9701@1",
          "io-wait:9963@1 --io-wait-driver-binding--> driver-store-binding:9961@1",
          "io-wait:9963@1 --io-wait-blocker--> irq-line-object:9931@1",
          "io-wait:9963@1 --io-wait-completion-irq--> irq-event:9964@1"
        ]
      }
    },
    "invariants": [
      "IoWait must bridge an exact pending WaitToken generation to an exact driver Store generation",
      "IoWait must bind to an exact DeviceObject and DriverStoreBinding generation",
      "IO blocker refs must belong to the same device generation",
      "A fake IRQ event can resolve the wait only when device, driver Store, and IRQ line attribution match",
      "Resolved IO waits are historical evidence and must not leave live ownership edges"
