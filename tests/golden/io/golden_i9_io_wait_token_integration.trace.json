        "violation": "io wait token generation is missing or not pending"
      },
      {
        "id": 6,
        "command": "record-io-wait",
        "device": "device-object:9701@2",
        "expected": "rejected",
        "violation": "io wait device generation is missing or inactive"
      },
      {
        "id": 7,
        "command": "record-io-wait",
        "blocker": "dma-buffer-object:other-device",
        "expected": "rejected",
        "violation": "io wait blocker generation is missing or inactive"
      },
      {
        "id": 8,
        "command": "cancel-io-wait",
        "reason": "timeout",
        "expected": "rejected",
        "violation": "io wait cancellation reason is not an io reason"
      }
    ]
  },
