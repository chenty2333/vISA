        "kind": "device-irq",
        "blocker": "irq-line-object:9931@1",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "record-io-wait",
        "io_wait": "io-wait:9963@1",
        "wait": "wait-token:9962@1",
        "driver_store": "store:2@2",
        "device": "device-object:9701@1",
        "driver_binding": "driver-store-binding:9961@1",
        "blocker": "irq-line-object:9931@1",
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "record-irq-event",
        "irq_event": "irq-event:9964@1",
        "irq_line": "irq-line-object:9931@1",
        "device": "device-object:9701@1",
        "driver_store": "store:2@2",
        "expected": "applied"
      },
      {
        "id": 4,
        "command": "resolve-io-wait",
        "io_wait": "io-wait:9963@1",
        "irq_event": "irq-event:9964@1",
        "expected": "applied"
      },
      {
        "id": 5,
        "command": "record-io-wait",
        "wait": "wait-token:stale-generation",
