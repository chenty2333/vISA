{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "I3-dma-buffer-object",
  "name": "golden_i3_dma_buffer_object",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md",
    "references/specs/semantic-contract-v0.1/02-object-identity-and-refs.md",
    "references/specs/semantic-contract-v0.1/03-contract-graph-edges.md",
    "references/specs/semantic-contract-v0.1/04-capability-authority.md"
  ],
  "no_goals": [
    "real DMA allocation",
    "real IOMMU mapping",
    "real descriptor ring ownership",
    "real DMA/MMIO/IRQ access",
    "network or block vertical implementation"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "record-descriptor-object",
        "descriptor": "descriptor:9901@1",
        "queue": "queue:9801@1",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "record-dma-buffer-object",
        "dma_buffer": "dma-buffer:9911@1",
        "descriptor": "descriptor:9901@1",
        "resource": "resource:3@1",
        "access": "read-write",
        "length": 2048,
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "record-dma-buffer-object",
        "descriptor": "descriptor:9901@2",
        "expected": "rejected",
        "violation": "dma buffer object descriptor generation is missing or inactive"
      },
      {
        "id": 4,
        "command": "record-dma-buffer-object",
        "resource_kind": "device",
        "expected": "rejected",
        "violation": "dma buffer object resource kind is not dma-buffer"
      },
      {
        "id": 5,
        "command": "record-dma-buffer-object",
        "resource": "resource:3@2",
        "expected": "rejected",
        "violation": "dma buffer object resource generation mismatch"
      },
      {
        "id": 6,
        "command": "record-dma-buffer-object",
        "length": 4096,
        "expected": "rejected",
        "violation": "dma buffer object length exceeds descriptor length"
      },
      {
        "id": 7,
        "command": "record-dma-buffer-object",
        "descriptor": "descriptor:9901@1",
        "expected": "rejected",
        "violation": "dma buffer object descriptor already has a buffer"
      }
    ]
  },
  "events": [
    {
      "kind": "DmaBufferObjectRecorded",
      "dma_buffer": "dma-buffer:9911@1",
      "descriptor": "descriptor:9901@1",
      "resource": "resource:3@1",
      "access": "read-write",
      "length": 2048
    }
  ],
  "expected": {
    "views": {
      "dma-buffer": {
        "id": 9911,
        "generation": 1,
        "state": "registered",
        "descriptor": "descriptor:9901@1",
        "resource": "resource:3@1",
        "access": "read-write",
        "length": 2048
      },
      "graph-live": {
        "edges": [
          "dma-buffer:9911@1 --dma-buffer-descriptor--> descriptor:9901@1",
          "dma-buffer:9911@1 --dma-buffer-resource--> resource:3@1"
        ]
      }
    },
    "invariants": [
      "DmaBufferObject must reference an exact registered DescriptorObject generation",
      "DmaBufferObject must reference an exact live ResourceKind::DmaBuffer generation",
      "DmaBufferObject length must be nonzero and fit within the descriptor length",
      "Only one registered DmaBufferObject may bind one DescriptorObject generation",
      "DmaBufferObject is semantic DMA buffer evidence, not substrate mapping truth"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "io_runtime_i3_dma_buffer_object_records_descriptor_and_resource_identity",
      "io_runtime_i3_rejects_stale_wrong_resource_or_duplicate_dma_buffer",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state",
      "semantic_roots_reject_dma_buffer_object_root_mismatch"
    ]
  }
}
