{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "I1-queue-object",
  "name": "golden_i1_queue_object",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md",
    "references/specs/semantic-contract-v0.1/02-object-identity-and-refs.md",
    "references/specs/semantic-contract-v0.1/03-contract-graph-edges.md"
  ],
  "no_goals": [
    "real virtqueue implementation",
    "real descriptor ring ownership",
    "real DMA/MMIO/IRQ access",
    "network or block vertical implementation",
    "smoltcp, virtio-drivers, fatfs, or ext4 adapter integration"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "record-device-object",
        "device": "device:9701@1",
        "resource": "resource:14@1",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "record-queue-object",
        "queue": "queue:9801@1",
        "device": "device:9701@1",
        "role": "rx",
        "queue_index": 0,
        "depth": 64,
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "record-queue-object",
        "device": "device:9701@2",
        "expected": "rejected",
        "violation": "queue object device generation is missing or inactive"
      },
      {
        "id": 4,
        "command": "record-queue-object",
        "depth": 0,
        "expected": "rejected",
        "violation": "queue object depth is zero"
      },
      {
        "id": 5,
        "command": "record-queue-object",
        "device": "device:9701@1",
        "queue_index": 0,
        "expected": "rejected",
        "violation": "queue object index already exists for device generation"
      }
    ]
  },
  "events": [
    {
      "kind": "QueueObjectRecorded",
      "queue": "queue:9801@1",
      "device": "device:9701@1",
      "role": "rx",
      "queue_index": 0,
      "depth": 64
    }
  ],
  "expected": {
    "views": {
      "queue": {
        "id": 9801,
        "generation": 1,
        "state": "registered",
        "name": "fake-io0-rx",
        "role": "rx",
        "queue_index": 0,
        "depth": 64,
        "device": "device:9701@1"
      },
      "graph-live": {
        "edges": [
          "queue:9801@1 --queue-device--> device:9701@1"
        ]
      }
    },
    "invariants": [
      "QueueObject must reference an exact registered DeviceObject generation",
      "QueueObject name must be nonempty",
      "QueueObject depth must be nonzero",
      "QueueObject queue_index is unique within a DeviceObject generation",
      "QueueObject is semantic queue evidence, not adapter-owned ring state"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "io_runtime_i1_queue_object_records_device_identity",
      "io_runtime_i1_rejects_stale_or_duplicate_queue",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state",
      "semantic_roots_reject_queue_object_root_mismatch"
    ]
  }
}
