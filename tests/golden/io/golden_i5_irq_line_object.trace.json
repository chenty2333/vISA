{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "I5-irq-line-object",
  "name": "golden_i5_irq_line_object",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md",
    "references/specs/semantic-contract-v0.1/02-object-identity-and-refs.md",
    "references/specs/semantic-contract-v0.1/03-contract-graph-edges.md",
    "references/specs/semantic-contract-v0.1/04-capability-authority.md"
  ],
  "no_goals": [
    "real IRQ registration",
    "real interrupt delivery",
    "PLIC/APIC programming",
    "real DMA/MMIO/IRQ access",
    "network or block vertical implementation"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "record-device-object",
        "device": "device:9701@1",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "record-irq-line-object",
        "irq_line": "irq-line:9931@1",
        "device": "device:9701@1",
        "resource": "resource:5@1",
        "irq_number": 5,
        "trigger": "level",
        "polarity": "active-high",
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "record-irq-line-object",
        "device": "device:9701@2",
        "expected": "rejected",
        "violation": "irq line object device generation is missing or inactive"
      },
      {
        "id": 4,
        "command": "record-irq-line-object",
        "resource_kind": "device",
        "expected": "rejected",
        "violation": "irq line object resource kind is not irq-line"
      },
      {
        "id": 5,
        "command": "record-irq-line-object",
        "resource": "resource:5@2",
        "expected": "rejected",
        "violation": "irq line object resource generation mismatch"
      },
      {
        "id": 6,
        "command": "record-irq-line-object",
        "device": "device:9701@1",
        "irq_number": 5,
        "expected": "rejected",
        "violation": "irq line object number already exists for device generation"
      }
    ]
  },
  "events": [
    {
      "kind": "IrqLineObjectRecorded",
      "irq_line": "irq-line:9931@1",
      "device": "device:9701@1",
      "resource": "resource:5@1",
      "irq_number": 5,
      "trigger": "level",
      "polarity": "active-high"
    }
  ],
  "expected": {
    "views": {
      "irq-line": {
        "id": 9931,
        "generation": 1,
        "state": "registered",
        "device": "device:9701@1",
        "resource": "resource:5@1",
        "irq_number": 5,
        "trigger": "level",
        "polarity": "active-high"
      },
      "graph-live": {
        "edges": [
          "irq-line:9931@1 --irq-line-device--> device:9701@1",
          "irq-line:9931@1 --irq-line-resource--> resource:5@1"
        ]
      }
    },
    "invariants": [
      "IrqLineObject must reference an exact registered DeviceObject generation",
      "IrqLineObject must reference an exact live ResourceKind::IrqLine generation",
      "IrqLineObject irq_number is unique within a DeviceObject generation",
      "IrqLineObject trigger and polarity are semantic descriptors",
      "IrqLineObject is semantic IRQ line evidence, not hardware interrupt-controller truth"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "io_runtime_i5_irq_line_object_records_device_and_resource_identity",
      "io_runtime_i5_rejects_stale_wrong_resource_or_duplicate_irq_line",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state",
      "semantic_roots_reject_irq_line_object_root_mismatch"
    ]
  }
}
