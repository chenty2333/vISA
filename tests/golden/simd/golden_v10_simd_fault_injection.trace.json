  "checkpoint": "V10-simd-fault-injection",
  "name": "golden_v10_simd_fault_injection",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/semantic-contract-v0.1/02-object-identity-and-refs.md",
    "references/specs/semantic-contract-v0.1/03-contract-graph-edges.md",
    "references/specs/semantic-contract-v0.1/10-command-transaction-surface.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "hardware vector trap delivery",
    "raw vector register payload storage",
    "real target-side cwasm execution",
    "target hardware SIMD enablement"
  ],
  "stimulus": {
    "preconditions": [
      "CodeObject declares riscv-v SIMD requirements",
      "TargetFeatureSet target-feature-set:21000@1 does not support riscv-v",
      "TargetExecutor records a simd-unsupported trap with exact Activation and CodeObject generations"
    ],
    "command": {
      "name": "record-simd-fault-injection",
      "injection": "simd-fault-injection:22010@1",
      "activation": "activation:90@2",
      "code_object": "code-object:18@6",
      "trap": "trap:28@1",
      "target_feature_set": "target-feature-set:21000@1",
      "result": "recorded unsupported SIMD fault evidence"
    }
  },
  "events": [
    {
      "kind": "SimdFaultInjectionRecorded",
      "source": "SemanticGraph::record_simd_fault_injection_with_id",
      "visible_as": "osctl simd-fault-injection list --json",
      "reason": "SIMD fault injection is a semantic evidence object, not an untyped trap note"
    },
    {
      "kind": "TargetTrapRecord",
      "source": "TargetExecutor::trap_exit_by_pc",
      "visible_as": "osctl graph --history --json",
      "reason": "trap attribution keeps historical activation/code/feature refs generation-exact"
    }
  ],
  "expected": {
    "views": {
      "simd-fault-injection": {
        "id": 22010,
        "generation": 1,
        "state": "recorded",
        "fault": {
          "kind": "unsupported-feature",
          "effect": "activation-trapped",
          "required_abi": "riscv-v",
          "vector_register_count": 32,
          "vector_register_bits": 128,
          "injected_faults": 1
        },
        "references": {
          "activation": {
            "kind": "activation",
            "id": 90,
            "generation": 2
          },
          "code_object": {
            "kind": "code-object",
            "id": 18,
            "generation": 6
          },
          "trap": {
            "kind": "trap",
            "id": 28,
            "generation": 1
          },
          "target_feature_set": {
            "kind": "target-feature-set",
            "id": 21000,
            "generation": 1
          },
          "vector_state": null
        }
      },
      "graph-edges": [
        {
          "from": "simd-fault-injection:22010@1",
          "relation": "simd-fault-injection->trap",
          "to": "trap:28@1",
          "mode": "historical"
        },
        {
          "from": "simd-fault-injection:22010@1",
          "relation": "simd-fault-injection->target-feature-set",
          "to": "target-feature-set:21000@1",
          "mode": "historical"
        }
      ],
      "contract-validation": {
        "ok": true,
        "violation_count": 0
      }
    },
    "invariants": [
      "unsupported SIMD fault injection cannot own a live VectorState",
      "illegal-instruction injection requires a supported SIMD target feature set",
      "SimdFaultInjectionRecord keeps activation/code/trap/feature refs generation-exact",
      "ContractGraph validates trap kind and SIMD attribution metadata",
      "osctl exposes the stable ViewV1 instead of dumping internal records"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "simd_runtime_v10_fault_injection_records_exact_trap_attribution",
      "simd_runtime_v10_rejects_unsupported_fault_with_live_vector_state",
      "simd_runtime_v10_rejects_illegal_instruction_on_unsupported_target",
      "simd_runtime_v10_fault_injection_validates_exact_trap_attribution",
      "simd_runtime_v10_rejects_fault_injection_trap_kind_mismatch",
      "simd_runtime_v10_rejects_fault_injection_wrong_ref_kind",
