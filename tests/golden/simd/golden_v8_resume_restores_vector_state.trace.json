  "stimulus": {
    "preconditions": [
      "Activation activation:88@4 was timer-preempted and has SavedContext saved-context:9070@2",
      "SavedContext saved-context:9070@2 contains saved vector-state:22002@1 with status clean",
      "VectorState vector-state:22002@1 is live-owned by activation:88@4 before resume",
