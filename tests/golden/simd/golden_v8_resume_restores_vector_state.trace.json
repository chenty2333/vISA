      "activation": "activation:88@4",
      "saved_context": "saved-context:9070@2",
      "saved_vector_state": "vector-state:22002@1",
      "result": "activation:88@5 activation-context:9070@5 restored_vector_state=vector-state:22003@1"
    }
  },
  "events": [
    {
      "kind": "VectorStateReleasedOnResume",
      "source": "SemanticGraph::resume_activation_with_id",
      "visible_as": "osctl inspect vector-state --json",
      "reason": "old saved VectorState becomes historical after resume"
    },
    {
      "kind": "VectorStateRestoredOnResume",
      "source": "SemanticGraph::resume_activation_with_id",
      "visible_as": "osctl activation-resume list --json",
      "reason": "resume restores vector ownership to the current activation generation"
    }
  ],
  "expected": {
    "views": {
      "activation-resume": {
        "id": 9071,
        "generation": 1,
        "state": "applied",
        "vector_restore": {
          "status": "clean",
          "saved_vector_state": {
            "kind": "vector-state",
            "id": 22002,
            "generation": 1
          },
          "restored_vector_state": {
            "kind": "vector-state",
            "id": 22003,
            "generation": 1
          }
        }
      },
      "saved-vector-state": {
        "id": 22002,
        "generation": 1,
        "state": "dropped",
        "owner_activation": "activation:88@4"
      },
      "restored-vector-state": {
        "id": 22003,
        "generation": 1,
        "state": "reserved",
        "owner_activation": "activation:88@5"
      },
      "graph-edges": [
        {
          "from": "activation-resume:9071@1",
          "relation": "restores-saved-vector-state",
          "to": "vector-state:22002@1",
          "mode": "historical"
        },
        {
          "from": "activation-resume:9071@1",
          "relation": "restored-vector-state",
          "to": "vector-state:22003@1",
          "mode": "historical"
        }
      ],
      "contract-validation": {
        "ok": true,
        "violation_count": 0
      }
    },
    "invariants": [
      "resume rejects dirty vector context when the vector state was not saved",
      "resume rejects saved/context vector ObjectRef generation mismatch",
      "old saved VectorState is dropped before it can remain a live edge to activation@old-generation",
      "restored VectorState is live-owned by activation@new-generation",
      "ActivationResume records saved and restored VectorState ObjectRefs"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "simd_runtime_v8_resume_restores_vector_state_to_current_activation_generation",
      "simd_runtime_v8_rejects_resume_when_dirty_vector_state_was_not_saved",
      "simd_runtime_v8_rejects_resume_vector_generation_mismatch",
      "activation_resume_view_v1_exposes_vector_restore_refs"
