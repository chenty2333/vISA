{
  "schema": "json-schema-draft-07",
  "title": "VMOS Checkpoint Report",
  "type": "object",
  "required": [
    "schema",
    "schema_version",
    "checkpoint",
    "phase",
    "status",
    "scope",
    "no_goals",
    "changed_files",
    "tests_and_traces",
    "validation_commands",
    "evidence",
    "residual_gaps",
    "next_checkpoint"
  ],
  "properties": {
    "schema": {
      "const": "vmos-checkpoint-report"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "checkpoint": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "status": {
      "enum": ["pass", "fail", "blocked"]
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "no_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests_and_traces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "enum": ["pass", "fail", "not-run", "blocked"]
          }
        }
      }
    },
    "evidence": {
      "type": "object"
    },
    "residual_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_checkpoint": {
      "type": "string"
    }
  }
}
