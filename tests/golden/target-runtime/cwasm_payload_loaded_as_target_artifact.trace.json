{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "C1-target-artifact-wraps-cwasm",
  "name": "cwasm_payload_loaded_as_target_artifact",
  "contract_refs": [
    "references/specs/target-runtime-abi/01-target-artifact-image.md",
    "references/specs/target-runtime-abi/05-target-profile-and-runtime-package.md"
  ],
  "no_goals": [
    "target-side-wasmtime-runtime",
    "real-cwasm-execution",
    "wasi-component-runtime"
  ],
  "stimulus": {
    "input": "aotc host-validation module",
    "artifact_identity": "TargetArtifactImage(.tart)",
    "payload": "CodeObject section contains wasmtime serialized cwasm bytes"
  },
  "events": [
    {
      "kind": "TargetArtifactImageParsed",
      "required_sections": [
        "Manifest",
        "ContractMetadata",
        "CodeObject",
        "HostcallImportTable",
        "TrapMap",
        "PcRangeTable",
        "ProfileRequirements",
        "Signature"
      ]
    },
    {
      "kind": "CodeObjectPayloadExtracted",
      "payload_format": "cwasm",
      "artifact_identity": "tart-hash",
      "code_identity": "cwasm-payload-hash"
    }
  ],
  "expected": {
    "bare_cwasm_is_not_vmos_artifact_abi": true,
    "target_artifact_hash_is_artifact_identity": true,
    "code_hash_is_payload_identity": true
  },
  "validation": {
    "ok": true,
    "commands": [
      "cargo run -p aotc -- all",
      "cargo run -p target_executor",
      "osctl inspect artifact --json semantic-package-v1.json"
    ]
  }
}
