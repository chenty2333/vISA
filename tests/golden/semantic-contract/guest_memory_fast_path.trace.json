{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "P8-guest-memory-object-model",
  "name": "guest_memory_fast_path",
  "contract_refs": [
    "references/specs/semantic-contract-v0.1/12-guest-memory-object-model.md",
    "references/specs/semantic-contract-v0.1/04-capability-authority.md"
  ],
  "no_goals": [
    "substrate-page-table-as-semantic-truth",
    "global-object-id-authority"
  ],
  "stimulus": {
    "slow_path": [
      "CapabilityLedger[StoreRef][slot]",
      "GuestAddressSpace",
      "VmaRegion",
      "PageObject",
      "DMW lease or copyin/copyout"
    ],
    "fast_path_cache": {
      "aspace_generation": 3,
      "vma_generation": 9,
      "page_generations": [11, 12],
      "cap_generation": 4
    }
  },
  "events": [
    {
      "kind": "FastPathAccepted",
      "checks": [
        "GuestAddressSpace generation unchanged",
        "VmaRegion generation unchanged",
        "PageObject generation unchanged",
        "capability generation unchanged"
      ]
    },
    {
      "kind": "FastPathInvalidated",
      "reason": "PageObject generation changed"
    }
  ],
  "expected": {
    "fast_path_is_cache_not_authority": true,
    "forged_global_object_id_does_not_authorize": true,
    "generation_change_forces_slow_path": true
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "guest_aspace_generation_mismatch_rejects_fast_path",
      "vma_generation_mismatch_rejects_dmw_map",
      "page_object_generation_mismatch_rejects_copyin",
      "forged_global_object_id_does_not_authorize_capability"
    ]
  }
}
