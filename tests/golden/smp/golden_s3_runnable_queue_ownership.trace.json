{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "S3-smp-runnable-queue-ownership",
  "name": "golden_s3_runnable_queue_ownership",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "activation cannot run on two harts",
    "IPI delivery",
    "remote preempt or park",
    "activation migration",
    "cross-hart scheduler decision"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "bind-runnable-queue-owner",
        "queue": "runnable-queue:1@1",
        "owner_hart": "hart:1@2"
      },
      {
        "id": 2,
        "command": "enqueue-runnable",
        "queue": "runnable-queue:1@2",
        "activation": "activation:11@1"
      }
    ]
  },
  "events": [
    {
      "kind": "RunnableQueueOwnerBound",
      "queue": "runnable-queue:1@2",
      "owner_hart": "hart:1@2"
    },
    {
      "kind": "RunnableQueued",
      "queue": "runnable-queue:1@2",
      "activation": "activation:11@2"
    }
  ],
  "expected": {
    "views": {
      "runnable_queue": {
        "kind": "runnable-queue",
        "id": 1,
        "generation": 2,
        "owner_hart": "hart:1@2",
        "entries": [
          "activation:11@2"
        ]
      },
      "scheduler": {
        "queues": [
          {
            "id": 1,
            "generation": 2,
            "owner_hart": "hart:1@2"
          }
        ]
      }
    },
    "invariants": [
      "RunnableQueue owner is a semantic HartId plus generation, not a hardware hart id",
      "Owner generation is validated before queue binding",
      "Queue owner cannot be rebound while live entries exist",
      "Activation runnable_queue_generation points to the post-bind queue generation",
      "Partial owner refs and future Hart generations are rejected"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "smp_runtime_s3_binds_runnable_queue_to_owner_hart_generation",
      "smp_runtime_s3_rejects_stale_hart_generation_and_live_rebinding",
      "smp_runtime_s3_invariants_reject_bad_queue_owner_generation",
      "smp_runtime_s3_invariants_reject_partial_queue_owner_ref",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state"
    ]
  }
}
