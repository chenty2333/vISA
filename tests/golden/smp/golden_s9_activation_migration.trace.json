    "stop-the-world rendezvous",
    "SMP code publish barrier",
    "real context migration",
    "real hardware scheduler execution",
    "target-side execution"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "create-runnable-queue",
        "queue": "runnable-queue:9005@1",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "bind-runnable-queue-owner",
        "queue": "runnable-queue:9005@2",
        "owner_hart": "hart:1@2",
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "migrate-runnable-activation",
        "migration": "activation-migration:9001@1",
        "activation": "activation:9004@4->5",
        "source_hart": "hart:2@4",
        "target_hart": "hart:1@2",
        "source_queue": "runnable-queue:9004@2",
        "target_queue": "runnable-queue:9005@2",
        "expected": "applied"
      },
      {
        "id": 4,
        "command": "migrate-runnable-activation",
        "activation": "activation:9004@3",
        "expected": "rejected",
        "violation": "activation migration source queue entry is missing"
      },
      {
        "id": 5,
        "command": "migrate-runnable-activation",
        "source_hart": "hart:2@4",
        "target_hart": "hart:2@4",
        "expected": "rejected",
        "violation": "activation migration requires distinct harts"
      },
      {
        "id": 6,
        "command": "migrate-runnable-activation",
        "source_hart": "hart:2@4",
        "target_hart": "hart:1@2",
        "target_queue": "runnable-queue:9006@2",
        "target_queue_owner": "hart:2@4",
        "expected": "rejected",
        "violation": "activation migration target queue owner mismatch"
      }
    ]
  },
  "events": [
    {
      "kind": "ActivationMigrated",
      "migration": "activation-migration:9001@1",
      "activation": "activation:9004@4->5",
      "source_hart": "hart:2@4",
      "target_hart": "hart:1@2",
      "source_queue": "runnable-queue:9004@2",
      "target_queue": "runnable-queue:9005@2"
    },
    {
      "kind": "RunnableDequeued",
      "queue": "runnable-queue:9004@2",
      "activation": "activation:9004@4"
    },
    {
      "kind": "RunnableQueued",
      "queue": "runnable-queue:9005@2",
      "activation": "activation:9004@5"
    },
    {
      "kind": "HartEventAttribution",
      "event_kind": "ActivationMigrationSourceRecorded",
      "hart": "hart:2@4",
      "activation": "activation:9004@4"
    },
    {
      "kind": "HartEventAttribution",
      "event_kind": "ActivationMigrationTargetRecorded",
      "hart": "hart:1@2",
      "activation": "activation:9004@5"
    }
  ],
  "expected": {
    "views": {
      "activation-migration": {
        "id": 9001,
        "generation": 1,
        "state": "applied",
        "activation": "activation:9004@4->5",
        "source_hart": "hart:2@4",
        "target_hart": "hart:1@2",
        "source_queue": "runnable-queue:9004@2",
        "target_queue": "runnable-queue:9005@2"
      },
      "scheduler": {
        "activation_migration_count": 1,
        "source_queue_entries_after": 0,
        "target_queue_entries_after": 1,
        "hart_event_attribution_count_delta": 2
      },
      "graph-history": {
        "edges": [
          "activation-migration:9001@1 --migrated-from--> activation:9004@4",
          "activation-migration:9001@1 --migrated-to--> activation:9004@5",
          "activation-migration:9001@1 --source-hart--> hart:2@4",
          "activation-migration:9001@1 --target-hart--> hart:1@2",
          "activation-migration:9001@1 --source-runnable-queue--> runnable-queue:9004@2",
          "activation-migration:9001@1 --target-runnable-queue--> runnable-queue:9005@2"
        ]
      }
    },
    "invariants": [
      "Activation migration must reference exact source and target hart generations",
      "Activation migration must reference exact source and target runnable queue generations",
      "Target runnable queue ownership must match the target hart identity",
      "Migrated activation must be Runnable on the source queue at the input generation",
      "Migration bumps the activation generation before enqueueing it on the target queue",
      "Migration emits both dequeue and queue events with before and after activation generations",
      "Migration records source and target per-hart attribution with exact activation generations",
      "Migration history edges remain historical after later hart or queue transitions"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "smp_runtime_s9_activation_migration_moves_runnable_between_hart_queues",
      "smp_runtime_s9_rejects_stale_activation_and_wrong_target_queue_owner",
      "smp_runtime_s9_history_still_requires_event_after_target_hart_advances",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state",
