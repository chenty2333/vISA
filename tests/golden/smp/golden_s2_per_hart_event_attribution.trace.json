{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "S2-per-hart-event-attribution",
  "name": "golden_s2_per_hart_event_attribution",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "SMP runnable queue ownership",
    "activation cannot run on two harts",
    "IPI delivery",
    "remote preempt or park",
    "activation migration"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "record-timer-interrupt",
        "timer_interrupt": "timer-interrupt:5@1",
        "hart": "hart:1@2",
        "hardware_hart": 0,
        "activation": "activation:11@3"
      }
    ]
  },
  "events": [
    {
      "kind": "TimerInterruptRecorded",
      "interrupt": "timer-interrupt:5@1",
      "hart": "hart:1@2",
      "hardware_hart": 0,
      "activation": "activation:11@3"
    }
  ],
  "expected": {
    "views": {
      "timer_interrupt": {
        "kind": "timer-interrupt",
        "id": 5,
        "generation": 1,
        "hart": "hart:1@2",
        "hardware_hart": 0
      },
      "hart_event_attribution": {
        "kind": "hart-event-attribution",
        "event_kind": "TimerInterruptRecorded",
        "hart": "hart:1@2",
        "activation": "activation:11@3"
      }
    },
    "invariants": [
      "Timer interrupts carry semantic HartId and Hart generation",
      "Hardware hart id is metadata, not authority or ObjectRef identity",
      "Hart event attribution records point to exact event ids",
      "Stale Hart generation rejects timer attribution",
      "Per-hart event history is osctl-visible"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "smp_runtime_s2_timer_interrupt_uses_exact_hart_ref_and_event_attribution",
      "smp_runtime_s2_rejects_stale_or_missing_hart_ref",
      "smp_runtime_s2_invariants_reject_bad_hart_event_generation",
      "smp_runtime_s2_invariants_reject_timer_without_hart_event_attribution",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state"
    ]
  }
}
