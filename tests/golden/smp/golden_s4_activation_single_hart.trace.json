{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "S4-activation-cannot-run-on-two-harts",
  "name": "golden_s4_activation_single_hart",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "IPI delivery",
    "remote preempt or park",
    "activation migration",
    "cross-hart scheduler decision",
    "stop-the-world safe point"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "bind-hart-current-activation",
        "hart": "hart:1@2",
        "activation": "activation:11@3",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "bind-hart-current-activation",
        "hart": "hart:2@2",
        "activation": "activation:11@3",
        "expected": "rejected",
        "violation": "activation is already current on another hart"
      }
    ]
  },
  "events": [
    {
      "kind": "HartCurrentActivationBound",
      "hart": "hart:1@3",
      "activation": "activation:11@3"
    }
  ],
  "expected": {
    "views": {
      "scheduler": {
        "current_activation_owners": [
          {
            "hart": "hart:1@3",
            "activation": "activation:11@3"
          }
        ]
      }
    },
    "invariants": [
      "A running activation may be current on at most one Hart",
      "BindHartCurrentActivation rejects an activation already current on another Hart",
      "The invariant catches malformed packages with duplicate current activation ownership",
      "Distinct activations may run on distinct harts"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "smp_runtime_s4_allows_distinct_current_activations_on_distinct_harts",
      "smp_runtime_s4_rejects_activation_current_on_another_hart",
      "smp_runtime_s4_invariants_reject_duplicate_current_activation",
      "scheduler_view_v1_exposes_current_activation_owners"
    ]
  }
}
