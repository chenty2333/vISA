{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "S6-remote-preempt",
  "name": "golden_s6_remote_preempt",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "remote park",
    "activation migration",
    "stop-the-world safe point",
    "SMP code publish barrier",
    "real hardware IPI delivery",
    "real target-side execution"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "remote-preempt-activation",
        "remote_preempt": "remote-preempt:31@1",
        "ipi": "ipi-event:21@1",
        "source_hart": "hart:1@2",
        "target_hart": "hart:2@3->4",
        "activation": "activation:11@3->4",
        "queue": "runnable-queue:2@2",
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "remote-preempt-activation",
        "ipi": "ipi-event:21@99",
        "expected": "rejected",
        "violation": "remote preempt ipi generation is missing"
      },
      {
        "id": 3,
        "command": "remote-preempt-activation",
        "target_hart": "hart:2@2",
        "expected": "rejected",
        "violation": "remote preempt target hart generation is missing"
      },
      {
        "id": 4,
        "command": "remote-preempt-activation",
        "queue": "runnable-queue:3@2",
        "expected": "rejected",
        "violation": "remote preempt queue is not owned by target hart"
      }
    ]
  },
  "events": [
    {
      "kind": "HartCurrentActivationCleared",
      "hart": "hart:2@4",
      "activation": "activation:11@3",
      "reason": "remote-preempt"
    },
    {
      "kind": "RemoteActivationPreempted",
      "remote_preempt": "remote-preempt:31@1",
      "ipi": "ipi-event:21@1",
      "source_hart": "hart:1@2",
      "target_hart": "hart:2@3->4",
      "activation": "activation:11@3->4",
      "queue": "runnable-queue:2@2"
    },
    {
      "kind": "RuntimeActivationStateChanged",
      "activation": "activation:11@4",
      "state": "runnable"
    },
    {
      "kind": "RunnableQueued",
      "activation": "activation:11@4",
      "queue": "runnable-queue:2@2"
    },
    {
      "kind": "HartEventAttribution",
      "event_kind": "RemotePreemptSourceRecorded",
      "hart": "hart:1@2"
    },
    {
      "kind": "HartEventAttribution",
      "event_kind": "RemotePreemptTargetRecorded",
      "hart": "hart:2@4",
      "activation": "activation:11@4"
    }
  ],
  "expected": {
    "views": {
      "remote-preempt": {
        "id": 31,
        "generation": 1,
        "state": "applied",
        "ipi": "ipi-event:21@1",
        "source_hart": "hart:1@2",
        "target_hart": "hart:2@3->4",
        "activation": "activation:11@3->4",
        "queue": "runnable-queue:2@2"
      },
      "scheduler": {
        "remote_preempt_count": 1,
        "ipi_event_count": 1,
        "hart_event_attribution_count_delta": 2
      },
      "graph-history": {
        "edges": [
          "remote-preempt:31@1 --caused-by-ipi--> ipi-event:21@1",
          "remote-preempt:31@1 --source-hart--> hart:1@2",
          "remote-preempt:31@1 --target-hart-before--> hart:2@3",
          "remote-preempt:31@1 --target-hart-after--> hart:2@4",
          "remote-preempt:31@1 --activation-before--> activation:11@3",
          "remote-preempt:31@1 --activation-after--> activation:11@4",
          "remote-preempt:31@1 --target-runnable-queue--> runnable-queue:2@2"
        ]
      }
    },
    "invariants": [
      "Remote preempt must be caused by a SchedulerKick IPI with exact generation",
      "Remote preempt source and target harts must be distinct",
      "Target hart must currently run the target activation at the requested generation",
      "Remote preempt clears the target hart current activation and bumps hart generation",
      "Remote preempt reclassifies the activation as runnable and enqueues it once",
      "Remote preempt records source and target per-hart attribution",
      "Remote preempt history edges are historical and do not imply live hart ownership"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "smp_runtime_s6_remote_preempt_requeues_target_hart_activation",
      "smp_runtime_s6_rejects_stale_ipi_and_wrong_target_generation",
      "smp_runtime_s6_rejects_queue_not_owned_by_target_hart",
      "smp_runtime_s6_invariants_reject_remote_preempt_ipi_generation_leak",
      "smp_runtime_s6_history_still_requires_event_after_activation_advances",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state",
      "semantic_roots_reject_remote_preempt_root_mismatch"
    ]
  }
}
