{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "S0-hart-object-state",
  "name": "golden_s0_hart_object_state",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "hart-local current activation",
    "cross-hart runnable queue ownership",
    "IPI delivery",
    "remote preempt or park",
    "activation migration"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "register-hart",
        "hart": "hart:1@1",
        "hardware_id": 0,
        "label": "boot-hart0",
        "boot": true
      },
      {
        "id": 2,
        "command": "set-hart-state",
        "hart": "hart:1@1",
        "state": "idle",
        "reason": "scheduler-ready"
      }
    ]
  },
  "events": [
    {
      "kind": "HartRegistered",
      "hart": "hart:1@1",
      "hardware_id": 0,
      "label": "boot-hart0",
      "boot": true
    },
    {
      "kind": "HartStateChanged",
      "hart": "hart:1@2",
      "from": "created",
      "to": "idle",
      "reason": "scheduler-ready"
    }
  ],
  "expected": {
    "views": {
      "hart": {
        "kind": "hart",
        "id": 1,
        "hardware_id": 0,
        "generation": 2,
        "state": "idle",
        "boot": true
      }
    },
    "invariants": [
      "Hart semantic object ids are nonzero ObjectRef ids",
      "Hardware hart id 0 is metadata, not the ObjectRef id",
      "Only one boot hart can be declared in S0",
      "Hart state transitions require exact generation"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "smp_runtime_s0_registers_hart_and_changes_state",
      "smp_runtime_s0_rejects_duplicate_hart_and_stale_state_generation",
      "smp_runtime_s0_invariants_reject_invalid_hart_identity",
      "smp_runtime_s0_invariants_reject_duplicate_hardware_hart",
      "semantic_roots_reject_hart_root_mismatch"
    ]
  }
}
