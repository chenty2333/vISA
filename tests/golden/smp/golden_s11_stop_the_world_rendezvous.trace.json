{
  "schema": "vmos-golden-trace",
  "schema_version": 1,
  "checkpoint": "S11-stop-the-world-rendezvous",
  "name": "golden_s11_stop_the_world_rendezvous",
  "contract_refs": [
    "references/roadmap.md",
    "references/specs/target-runtime-abi/02-code-publish-and-cache.md",
    "references/specs/target-runtime-abi/08-default-profile.md",
    "references/specs/execution-flow/agent-checkpoint-report.md"
  ],
  "no_goals": [
    "SMP code publish barrier",
    "W^X page-table update",
    "local or remote icache sync",
    "real interrupt masking",
    "trap-gate forced parking",
    "real target-side execution"
  ],
  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "record-smp-safe-point",
        "safe_point": "smp-safe-point:9001@1",
        "participants": [
          "hart:1@2",
          "hart:2@4"
        ],
        "expected": "applied"
      },
      {
        "id": 2,
        "command": "complete-stop-the-world-rendezvous",
        "rendezvous": "stop-the-world-rendezvous:9101@1",
        "epoch": 1,
        "safe_point": "smp-safe-point:9001@1",
        "stop_new_activations": true,
        "expected": "applied"
      },
      {
        "id": 3,
        "command": "complete-stop-the-world-rendezvous",
        "safe_point": "smp-safe-point:9001@2",
        "expected": "rejected",
        "violation": "stop-the-world rendezvous safe point is missing"
      },
      {
        "id": 4,
        "command": "complete-stop-the-world-rendezvous",
        "stop_new_activations": false,
        "expected": "rejected",
        "violation": "stop-the-world rendezvous must stop new activations"
      },
      {
        "id": 5,
        "command": "complete-stop-the-world-rendezvous",
        "safe_point": "smp-safe-point:9001@1",
        "hart_advanced_after_safe_point": "hart:1@3",
        "expected": "rejected",
        "violation": "stop-the-world rendezvous participant generation is stale"
      }
    ]
  },
  "events": [
    {
      "kind": "SmpSafePointRecorded",
      "safe_point": "smp-safe-point:9001@1",
      "participant_count": 2
    },
    {
      "kind": "StopTheWorldRendezvousCompleted",
      "rendezvous": "stop-the-world-rendezvous:9101@1",
      "epoch": 1,
      "safe_point": "smp-safe-point:9001@1",
      "participant_count": 2
    },
    {
      "kind": "HartEventAttribution",
      "event_kind": "StopTheWorldHartParked",
      "hart": "hart:1@2"
    },
    {
      "kind": "HartEventAttribution",
      "event_kind": "StopTheWorldHartParked",
      "hart": "hart:2@4"
    }
  ],
  "expected": {
    "views": {
      "stop-the-world-rendezvous": {
        "id": 9101,
        "generation": 1,
        "epoch": 1,
        "state": "completed",
        "safe_point": "smp-safe-point:9001@1",
        "stop_new_activations": true,
        "participants": [
          "hart:1@2",
          "hart:2@4"
        ],
        "participant_count": 2
      },
      "scheduler": {
        "stop_the_world_rendezvous_count": 1,
        "hart_event_attribution_count_delta": 2
      },
      "graph-history": {
        "edges": [
          "stop-the-world-rendezvous:9101@1 --rendezvous-safe-point--> smp-safe-point:9001@1",
          "stop-the-world-rendezvous:9101@1 --coordinator-hart--> hart:1@2",
          "stop-the-world-rendezvous:9101@1 --participant-hart--> hart:2@4"
        ]
      }
    },
    "invariants": [
      "Rendezvous must reference an exact recorded SMP safe point generation",
      "Rendezvous must stop new activations before completion is recorded",
      "Every safe point participant must still be the current quiesced hart generation at completion time",
      "Completed rendezvous is historical evidence and survives later hart generation changes",
      "Per-hart parked attribution must be osctl-visible"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "smp_runtime_s11_stop_the_world_rendezvous_completes_from_safe_point",
      "smp_runtime_s11_rejects_missing_stop_flag_stale_safe_point_and_hart",
      "smp_runtime_s11_history_survives_later_hart_transition",
      "preemptive_runtime_views_expose_task_activation_and_scheduler_state",
      "semantic_roots_reject_stop_the_world_rendezvous_root_mismatch"
    ]
  }
}
