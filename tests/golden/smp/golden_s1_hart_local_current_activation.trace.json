    {
      "kind": "HartCurrentActivationCleared",
      "hart": "hart:1@4",
      "activation": "activation:11@3",
      "reason": "timer-preempt"
    }
  ],
  "expected": {
    "views": {
      "hart_running": {
        "kind": "hart",
        "id": 1,
        "generation": 3,
        "state": "running",
        "current_activation": "activation:11@3"
      },
      "hart_cleared": {
        "kind": "hart",
        "id": 1,
        "generation": 4,
        "state": "idle",
        "current_activation": null
      }
    },
    "invariants": [
      "Binding requires exact Hart generation",
      "Binding requires an idle Hart",
      "Binding requires a running Activation generation",
      "Running Hart must carry current activation/task/store attribution",
      "Idle/Parked/Offline/Faulted Hart cannot retain current activation"
