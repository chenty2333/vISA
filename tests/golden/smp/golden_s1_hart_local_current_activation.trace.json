  "stimulus": {
    "commands": [
      {
        "id": 1,
        "command": "bind-hart-current-activation",
        "hart": "hart:1@2",
        "activation": "activation:11@3"
      },
      {
        "id": 2,
        "command": "clear-hart-current-activation",
        "hart": "hart:1@3",
        "activation": "activation:11@3",
        "reason": "timer-preempt"
      }
    ]
  },
  "events": [
    {
      "kind": "HartCurrentActivationBound",
      "hart": "hart:1@3",
      "activation": "activation:11@3",
      "from": "idle"
