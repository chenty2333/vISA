    "command": {
      "name": "record-framebuffer-object",
      "framebuffer": "framebuffer-object:23001@1",
      "resource": "resource:27@1",
      "geometry": {
        "width": 800,
        "height": 600,
        "stride_bytes": 3200,
        "pixel_format": "xrgb8888",
        "byte_len": 1920000
      },
      "result": "registered semantic framebuffer object without write authority"
    }
  },
  "events": [
    {
      "kind": "ResourceRegistered",
      "source": "SemanticGraph::register_resource",
      "visible_as": "osctl graph --history --json",
      "reason": "FramebufferObject must reference a generation-exact semantic backing resource"
    },
    {
      "kind": "FramebufferObjectRecorded",
      "source": "SemanticGraph::record_framebuffer_object_with_id",
      "visible_as": "osctl framebuffer-object list --json",
      "reason": "Framebuffer identity and geometry are semantic evidence, not substrate mapping truth"
    }
  ],
  "expected": {
    "views": {
      "framebuffer-object": {
        "id": 23001,
        "generation": 1,
        "state": "registered",
        "identity": {
          "name": "fb0"
        },
        "geometry": {
          "width": 800,
          "height": 600,
          "stride_bytes": 3200,
          "pixel_format": "xrgb8888",
          "byte_len": 1920000
        },
        "authority": {
          "write_requires": "display-capability-and-framebuffer-window-lease",
          "raw_mapping_is_semantic_truth": false
        },
        "references": {
          "resource": {
            "kind": "resource",
            "id": 27,
            "generation": 1
          },
          "event": {
            "id": 554
          }
        }
      },
      "graph-edges": [
        {
          "from": "framebuffer-object:23001@1",
          "relation": "framebuffer-object->resource",
          "to": "resource:27@1",
          "mode": "live"
        },
        {
          "from": "framebuffer-object:23001@1",
          "relation": "framebuffer-object->event",
          "to": "event:554@1",
          "mode": "historical"
        }
      ],
      "contract-validation": {
        "ok": true,
        "violation_count": 0
      }
    },
    "invariants": [
      "FramebufferObject id/generation is a first-class ObjectRef",
      "FramebufferObject must reference a live framebuffer Resource generation",
      "stride_bytes must cover visible row bytes",
      "byte_len must cover stride_bytes * height",
      "pixel_format is explicit semantic metadata",
      "raw substrate mapping is not semantic truth"
    ]
  },
  "validation": {
    "ok": true,
    "required_tests": [
      "display_runtime_g0_framebuffer_object_records_contract_identity",
      "display_runtime_g0_rejects_bad_resource_or_geometry",
      "display_runtime_g0_invariants_reject_resource_generation_leak",
      "display_runtime_g0_contract_graph_rejects_bad_framebuffer_geometry",
      "semantic_roots_reject_framebuffer_object_root_mismatch",
