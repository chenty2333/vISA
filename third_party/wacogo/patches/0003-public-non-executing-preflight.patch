+
+// CheckInstantiation verifies that opts satisfy every declared import of c
+// without executing the component's instantiation plan or any core start
+// function. It checks import kinds unconditionally and checks component-model
+// subtyping for providers that carry wasmparser type handles.
+func (c *Component) CheckInstantiation(opts ...InstantiateOption) error {
+	return c.checkInstantiationConfig(applyInstantiateOptions(opts))
+}
