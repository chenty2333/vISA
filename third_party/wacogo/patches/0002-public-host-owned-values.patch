+func TestNewValOwnHandle_TransferOwn(t *testing.T) {
+	rt := &testResourceType{name: "R"}
+	val := NewValOwnHandle(rt, 17)
+	if val.Type() != rt || val.Rep() != 17 {
+		t.Fatalf("new own = (type=%v, rep=%d), want (type=%v, rep=17)", val.Type(), val.Rep(), rt)
+	}
+
+	dst := newStubResourceTable()
+	h, err := val.TransferOwn(dst)
+	if err != nil {
+		t.Fatalf("TransferOwn: %v", err)
+	}
+	if h.Type() != rt || h.Rep() != 17 {
+		t.Fatalf("transferred own = (type=%v, rep=%d), want (type=%v, rep=17)", h.Type(), h.Rep(), rt)
+	}
+	if _, err := val.TransferOwn(dst); err == nil || !strings.Contains(err.Error(), "transferred") {
+		t.Fatalf("second TransferOwn err = %v, want transferred", err)
+	}
+}
+
+func TestNewValOwnHandle_DropRunsDtor(t *testing.T) {
+	called := false
+	rt := &testResourceTypeWithDtor{
+		name: "R",
+		dtor: func(_ context.Context, rep uint32) error {
+			called = true
+			if rep != 23 {
+				t.Errorf("dtor rep = %d, want 23", rep)
+			}
+			return nil
+		},
+	}
+	val := NewValOwnHandle(rt, 23)
+	if err := val.Drop(context.Background()); err != nil {
+		t.Fatalf("Drop: %v", err)
+	}
+	if !called {
+		t.Fatal("dtor not called")
+	}
+}
