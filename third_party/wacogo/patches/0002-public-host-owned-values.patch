+func TestNewValOwnHandleFromHostResource(t *testing.T) {
+	ctx := context.Background()
+	engine := wacogo.NewEngine(ctx)
+	defer engine.Close(ctx)
+
+	builder := engine.NewHostBuilder("own-value-test")
+	builder.AddResource("item", nil)
+	component, err := builder.Build(ctx)
+	if err != nil {
+		t.Fatalf("Build: %v", err)
+	}
+	defer component.Close(ctx)
+	instance, err := component.Instantiate(ctx)
+	if err != nil {
+		t.Fatalf("Instantiate: %v", err)
+	}
+	defer instance.Close(ctx)
+
+	rt, ok := instance.Core().ExportedType("item").(*wacogo.TypeResource)
+	if !ok {
+		t.Fatalf("item type = %T, want *wacogo.TypeResource", instance.Core().ExportedType("item"))
+	}
+	eh := instance.RegisterResource("payload")
+	own := wacogo.NewValOwnHandle(rt, uint32(eh))
+	if own.Rep() != uint32(eh) {
+		t.Fatalf("own.Rep() = %d, want %d", own.Rep(), eh)
+	}
+	if err := own.Drop(ctx); err != nil {
+		t.Fatalf("Drop: %v", err)
+	}
+	if _, live := instance.LookupResource(eh); live {
+		t.Fatal("host resource remained live after owned value Drop")
+	}
+}
+
+func TestNewValOwnHandleRejectsNilType(t *testing.T) {
+	defer func() {
+		if recover() == nil {
+			t.Fatal("NewValOwnHandle(nil, ...) did not panic")
+		}
+	}()
+	_ = wacogo.NewValOwnHandle(nil, 1)
