From: vISA downstream patchset
Subject: [PATCH 1/3] host: export root named defined types from host instances
Upstream-base: 3de16a61796ce02d29795e4a074f37a33e6ebd87
License: Apache-2.0

The host builder accepted AddType declarations but discarded them after
validation. Preserve root named types, materialize them in runtime type slots,
export them from the live instance, and advertise them through the parser-side
instance type. This fixes ordinary named defined types, as well as resources,
for the root host-component scope exercised by vISA. Nested host scopes remain
outside this patch.

diff --git a/host/builder.go b/host/builder.go
index ea30fad..aaf28cf 100644
--- a/host/builder.go
+++ b/host/builder.go
@@ -313,6 +313,11 @@ func buildScopeTree(b *Builder, comp *Component, root *scope) error {
 			})
 		}
 		for _, ts := range s.types {
+			if ts.name != "" {
+				if err := check(ts.name); err != nil {
+					return nil, err
+				}
+			}
 			if err := validateTopLevelTypeExpr(ts.expr); err != nil {
 				return nil, fmt.Errorf("wacogo/host: AddType %q: %w", ts.name, err)
 			}
@@ -344,6 +349,7 @@ func buildScopeTree(b *Builder, comp *Component, root *scope) error {
 	// resolver. Only root-scope ResourceTypeRefs are supported in this
 	// pass; nested scopes have no refs yet.
 	comp.resourceRefs = root.resourceRefs
+	comp.types = append([]typeDecl(nil), root.types...)
 	return nil
 }
 
