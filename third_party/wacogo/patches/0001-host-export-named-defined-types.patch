diff --git a/host/component_test.go b/host/component_test.go
index e1405f5..a7c17b9 100644
--- a/host/component_test.go
+++ b/host/component_test.go
@@ -203,3 +203,35 @@ func TestInstantiateExportsResourceType(t *testing.T) {
 		t.Errorf(`ExportedType("r") = %T, want *core.TypeResource`, got)
 	}
 }
+
+func TestInstantiateExportsNamedDefinedType(t *testing.T) {
+	ctx := context.Background()
+	b, _ := newTestBuilder(t)
+	b.AddType("problem", Variant{Cases: []Case{
+		{Name: "denied"},
+		{Name: "detail", Payload: String},
+	}})
+
+	comp, err := b.Build(ctx)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer comp.Close(ctx)
+
+	inst, err := comp.Instantiate(ctx)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer inst.Close(ctx)
+
+	got, ok := inst.Core().ExportedType("problem").(core.TypeVariant)
+	if !ok {
+		t.Fatalf(`ExportedType("problem") = %T, want core.TypeVariant`, inst.Core().ExportedType("problem"))
+	}
+	if len(got.Cases) != 2 || got.Cases[0].Name != "denied" || got.Cases[1].Name != "detail" {
+		t.Fatalf("ExportedType problem cases = %#v", got.Cases)
+	}
+	if _, ok := got.Cases[1].Payload.(core.TypeString); !ok {
+		t.Fatalf("ExportedType problem detail payload = %T, want core.TypeString", got.Cases[1].Payload)
+	}
+}
